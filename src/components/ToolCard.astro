---
import type { Tool } from '../data/tools';
interface Props { tool: Tool; }
const { tool } = Astro.props;
const isAvailable = tool.status === 'available';
const Tag = isAvailable ? 'a' : 'div';
---
<Tag
  href={isAvailable ? tool.path : undefined}
  data-tool-id={tool.id}
  class:list={[
    'group block rounded-[var(--radius-card)] border border-edge bg-surface p-5 transition-all',
    isAvailable
      ? 'hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-[0_8px_24px_-12px_rgba(0,0,0,0.18)]'
      : 'cursor-default opacity-60',
  ]}
>
  <div class="mb-3 flex items-center justify-between">
    <span class="text-2xl">{tool.icon}</span>
    {!isAvailable && <span class="rounded-full bg-edge px-2 py-0.5 text-xs text-muted">即將推出</span>}
  </div>
  <h3 class="font-serif text-lg text-ink">{tool.title}</h3>
  <p class="mt-1 text-sm text-muted">{tool.description}</p>
</Tag>
